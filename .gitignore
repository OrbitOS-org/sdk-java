# Ignore Gradle project-specific cache directory
.gradle

# Ignore Gradle build output directory
build/
app/build/
app/bin/

# Ignore package output directory
package/

# Ignore certificados e chaves privadas (em todos os locais)
**/*.crt
**/*.key
**/*.pem
**/*.p12
**/*.pfx
!app/src/main/resources/certs/README.md
!certs/README.md
!app/certs/README.md

# Ignore arquivos compilados
*.class
#*.jar
!gradle/wrapper/gradle-wrapper.jar

# Ignore arquivos do IDE
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# Ignore arquivos do sistema
.DS_Store
Thumbs.db

# Ignore logs
*.log
